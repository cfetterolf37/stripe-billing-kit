# ============================================================
# Stripe Billing Kit — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
#
# Where to find each value is noted inline.
# ============================================================

# ─── App ──────────────────────────────────────────────────────
# Your app's public URL. Used for Stripe redirect URLs.
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Dashboard → Settings → API → service_role key
# WARNING: Never expose this in client-side code. Server/webhooks only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe (Secret) ──────────────────────────────────────────
# Dashboard → Developers → API keys → Secret key
# WARNING: Never expose this in client-side code. Server only.
STRIPE_SECRET_KEY=sk_test_...

# Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Local dev: get from `stripe listen` output (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Price IDs (Public — safe for client) ──────────────
# Dashboard → Products → your product → Pricing
# Create separate prices for monthly and yearly billing.
# These are PRICE IDs (price_xxx), not PRODUCT IDs (prod_xxx).

NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID=price_...

NEXT_PUBLIC_STRIPE_TEAM_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_TEAM_YEARLY_PRICE_ID=price_...
